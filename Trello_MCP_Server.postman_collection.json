{
  "info": {
    "name": "Trello MCP Server",
    "description": "Test the Trello MCP server (example: http://localhost:8000).\n\n**How to use:**\n1. Run '1. Connect (SSE)' — in the response body look for the line starting with `data:`, it will contain `/messages/?session_id=XXXXXXXX`. Copy that UUID.\n2. Set the `session_id` collection variable to that UUID.\n3. Run '2. Initialize' — required before calling any tools.\n4. Run any tool requests.\n\nAll tool calls POST to `/messages/?session_id={{session_id}}` with a JSON-RPC 2.0 body.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "session_id",
      "value": "",
      "type": "string",
      "description": "Set this from the `data:` line returned by the SSE connect request"
    }
  ],
  "item": [
    {
      "name": "1. Connect (SSE)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "text/event-stream"
          }
        ],
        "url": {
          "raw": "{{base_url}}/sse",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "sse"
          ]
        },
        "description": "Open the SSE stream. The server will immediately send an event like:\n\n  event: endpoint\n  data: /messages/?session_id=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX\n\nCopy the UUID from the `data:` line and paste it into the `session_id` collection variable."
      }
    },
    {
      "name": "2. Initialize",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"initialize\",\n  \"params\": {\n    \"protocolVersion\": \"2024-11-05\",\n    \"capabilities\": {},\n    \"clientInfo\": {\n      \"name\": \"postman\",\n      \"version\": \"1.0.0\"\n    }\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/messages/?session_id={{session_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "messages",
            ""
          ],
          "query": [
            {
              "key": "session_id",
              "value": "{{session_id}}"
            }
          ]
        },
        "description": "Must be called once after connecting. Returns 202 Accepted. The actual response arrives via the SSE stream."
      }
    },
    {
      "name": "3. List Tools",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 2,\n  \"method\": \"tools/list\",\n  \"params\": {}\n}"
        },
        "url": {
          "raw": "{{base_url}}/messages/?session_id={{session_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "messages",
            ""
          ],
          "query": [
            {
              "key": "session_id",
              "value": "{{session_id}}"
            }
          ]
        },
        "description": "List all available tools and their input schemas. Useful for verifying the server is running and tools are registered."
      }
    },
